<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ShutdownTimer.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:ShutdownTimer.Helpers">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ── Theme Dictionaries (theme-aware resources) ── -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="PageBackground" Color="#0A0A14" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#2A2A45" />
                    <SolidColorBrush x:Key="CardBorderGlowBrush" Color="#3300D4FF" />
                    <SolidColorBrush x:Key="SubtleForeground" Color="#8888AA" />
                    <SolidColorBrush x:Key="DimForeground" Color="#555577" />
                    <SolidColorBrush x:Key="PageTitleForeground" Color="White" />
                    <AcrylicBrush x:Key="GlassCardBrush"
                        TintColor="#1A1A2E" TintOpacity="0.75"
                        FallbackColor="#1A1A2E" />
                    <AcrylicBrush x:Key="GlassCardBrushHover"
                        TintColor="#252540" TintOpacity="0.80"
                        FallbackColor="#252540" />
                    <AcrylicBrush x:Key="GlassNavBrush"
                        TintColor="#0F0F1A" TintOpacity="0.85"
                        FallbackColor="#0F0F1A" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="PageBackground" Color="#F5F5F8" />
                    <SolidColorBrush x:Key="CardBorderBrush" Color="#D8D8E0" />
                    <SolidColorBrush x:Key="CardBorderGlowBrush" Color="#6600D4FF" />
                    <SolidColorBrush x:Key="SubtleForeground" Color="#606080" />
                    <SolidColorBrush x:Key="DimForeground" Color="#8888AA" />
                    <SolidColorBrush x:Key="PageTitleForeground" Color="#1A1A2E" />
                    <AcrylicBrush x:Key="GlassCardBrush"
                        TintColor="#FFFFFF" TintOpacity="0.80"
                        FallbackColor="#FFFFFF" />
                    <AcrylicBrush x:Key="GlassCardBrushHover"
                        TintColor="#F0F0F5" TintOpacity="0.85"
                        FallbackColor="#F0F0F5" />
                    <AcrylicBrush x:Key="GlassNavBrush"
                        TintColor="#EAEAF0" TintOpacity="0.90"
                        FallbackColor="#EAEAF0" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- ── NavigationView Selection Overrides ── -->
            <SolidColorBrush x:Key="NavigationViewSelectionIndicatorForeground" Color="#00D4FF" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="White" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="White" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="White" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#1A00D4FF" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#2600D4FF" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="#3300D4FF" />

            <!-- Converters -->
            <helpers:InverseBoolConverter x:Key="InverseBool" />
            <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <helpers:BoolToStatusColorConverter x:Key="BoolToStatusColor" />
            <helpers:IndexToVisibilityConverter x:Key="IndexToVisibility" />
            <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
            <helpers:StringToVisibilityConverter x:Key="StringToVisibility" />
            <helpers:BoolToInfoBarSeverityConverter x:Key="BoolToInfoBarSeverity" />
            <helpers:PercentageStringConverter x:Key="PercentageString" />

            <!-- ── Accent Brushes (Dynamically linked to Windows System Color) ── -->
            <SolidColorBrush x:Key="AccentGlowBrush" Color="{ThemeResource SystemAccentColor}" />
            <SolidColorBrush x:Key="AccentGlowDimBrush" Color="{ThemeResource SystemAccentColorLight2}" />
            <SolidColorBrush x:Key="AccentWarmBrush" Color="#FF6B35" />
            <SolidColorBrush x:Key="AccentGreenBrush" Color="#00E676" />
            <SolidColorBrush x:Key="AccentRedBrush" Color="#FF5252" />
            <SolidColorBrush x:Key="AccentPurpleBrush" Color="#BB86FC" />

            <!-- ── Glass Card Style ── -->
            <Style x:Key="GlassCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource GlassCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14" />
            </Style>

            <!-- ── Glow Card Style (active/highlighted) ── -->
            <Style x:Key="GlowCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource GlassCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderGlowBrush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <!-- ── Hoverable Interactive Card ── -->
            <Style x:Key="HoverCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource GlassCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Transitions">
                    <Setter.Value>
                        <TransitionCollection>
                            <ContentThemeTransition />
                        </TransitionCollection>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ── Active Nav Badge (InfoBadge Style) ── -->
            <Style x:Key="DotInfoBadgeStyle" TargetType="InfoBadge">
                <Setter Property="Background" Value="{StaticResource AccentGlowBrush}" />
                <Setter Property="Width" Value="8" />
                <Setter Property="Height" Value="8" />
                <Setter Property="Margin" Value="0,0,0,0" />
            </Style>

            <!-- ── Glow Button ── -->
            <Style x:Key="GlowAccentButton" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#2600D4FF" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{StaticResource AccentGlowBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentGlowBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,7" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <!-- ── Subtle Button ── -->
            <Style x:Key="SubtleButton" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#0DFFFFFF" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{ThemeResource SubtleForeground}" />
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="#1AFFFFFF" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="11,6" />
            </Style>

            <!-- ── Danger Button (softened red) ── -->
            <Style x:Key="DangerButton" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <SolidColorBrush Color="#1AE05555" />
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground">
                    <Setter.Value>
                        <SolidColorBrush Color="#E07070" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <SolidColorBrush Color="#40E05555" />
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="11,6" />
            </Style>

            <!-- ── Section Title ── -->
            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource SubtleForeground}" />
                <Setter Property="CharacterSpacing" Value="60" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <!-- ── Big Timer Display ── -->
            <Style x:Key="TimerDisplay" TargetType="TextBlock">
                <Setter Property="FontSize" Value="52" />
                <Setter Property="FontWeight" Value="SemiLight" />
                <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
                <Setter Property="Foreground" Value="{ThemeResource PageTitleForeground}" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <!-- ── Stat Value ── -->
            <Style x:Key="StatValue" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource PageTitleForeground}" />
            </Style>

            <Style x:Key="StatLabel" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource SubtleForeground}" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- ── Redesign Typography ── -->
            <Style x:Key="PageEyebrow" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="90" />
                <Setter Property="Foreground" Value="{StaticResource AccentGlowBrush}" />
            </Style>

            <Style x:Key="PageHeading" TargetType="TextBlock">
                <Setter Property="FontSize" Value="24" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource PageTitleForeground}" />
            </Style>

            <Style x:Key="PageDescription" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource SubtleForeground}" />
            </Style>

            <Style x:Key="CardTitle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource PageTitleForeground}" />
            </Style>

            <Style x:Key="CardBody" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource SubtleForeground}" />
            </Style>

            <!-- ── Redesign Cards ── -->
            <Style x:Key="HeroCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource GlassCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderGlowBrush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="18" />
            </Style>

            <Style x:Key="CommandCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource GlassCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="13" />
                <Setter Property="Transitions">
                    <Setter.Value>
                        <TransitionCollection>
                            <ContentThemeTransition />
                        </TransitionCollection>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="CompactCard" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource GlassCardBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="10" />
            </Style>

            <Style x:Key="StatusPill" TargetType="Border">
                <Setter Property="Background" Value="#1A00D4FF" />
                <Setter Property="BorderBrush" Value="#3300D4FF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="8,3" />
            </Style>

            <Style x:Key="PreviewPanel" TargetType="Border">
                <Setter Property="Background" Value="#1200D4FF" />
                <Setter Property="BorderBrush" Value="#2600D4FF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="10,7" />
            </Style>

            <Style x:Key="BrandBadge" TargetType="Border">
                <Setter Property="Background" Value="#2200D4FF" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentGlowBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="7" />
            </Style>

            <Style x:Key="DangerPill" TargetType="Border">
                <Setter Property="Background" Value="#1AFF5252" />
                <Setter Property="BorderBrush" Value="#44FF5252" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,5" />
            </Style>

            <Style x:Key="SuccessPill" TargetType="Border">
                <Setter Property="Background" Value="#1A00E676" />
                <Setter Property="BorderBrush" Value="#4400E676" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="10,5" />
            </Style>

            <!-- ── Help Info Button ── -->
            <Style x:Key="HelpInfoButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{ThemeResource SubtleForeground}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="4" />
                <Setter Property="Width" Value="28" />
                <Setter Property="Height" Value="28" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
