<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ShutdownTimer.Views.IdleDetectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer Padding="22,16,22,14">
        <StackPanel Spacing="12" MaxWidth="760" HorizontalAlignment="Left">

            <!-- Page Title -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="IDLE RULE" Style="{StaticResource PageEyebrow}" />
                    <TextBlock Text="Save power when you step away" Style="{StaticResource PageHeading}" />
                    <TextBlock Text="Run a power action only after the whole system has been idle for your chosen threshold."
                               Style="{StaticResource PageDescription}" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource HelpInfoButton}" VerticalAlignment="Top">
                    <FontIcon Glyph="&#xE897;" FontSize="16" />
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel Spacing="8" MaxWidth="300">
                                <TextBlock Text="Idle Detection Help" FontWeight="SemiBold" Foreground="{ThemeResource PageTitleForeground}" />
                                <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource SubtleForeground}" FontSize="13"
                                           Text="Set a threshold in minutes. If no mouse or keyboard activity is detected for that long, the chosen action runs automatically." />
                                <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource SubtleForeground}" FontSize="13"
                                           Text="The idle timer monitors system-wide input, not just this app. Any mouse move or keypress resets the counter to zero." />
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource AccentWarmBrush}" FontSize="12"
                                           Text="Tip: If it triggers too early, check for apps that simulate input (e.g. presentation software)." />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!-- Idle Time Display Card -->
            <Border Style="{StaticResource GlowCard}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="CURRENT IDLE TIME" Style="{StaticResource SectionTitle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.CurrentIdleDisplay, Mode=OneWay}"
                               Style="{StaticResource TimerDisplay}" FontSize="44" />
                    <ProgressBar Value="{x:Bind ViewModel.IdleProgressPercent, Mode=OneWay}"
                                 Maximum="100" Height="4" CornerRadius="2"
                                 Foreground="{StaticResource AccentWarmBrush}"
                                 Background="{ThemeResource CardBorderBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.ThresholdDisplay, Mode=OneWay}"
                               FontSize="12" Foreground="{ThemeResource DimForeground}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               FontSize="13" Foreground="{ThemeResource SubtleForeground}"
                               HorizontalAlignment="Center" />
                    </StackPanel>
                    <Border Grid.Column="1" Style="{StaticResource BrandBadge}" Width="46" Height="46" VerticalAlignment="Top">
                        <FontIcon Glyph="&#xEC46;" FontSize="24" Foreground="{StaticResource AccentWarmBrush}" />
                    </Border>
                </Grid>
            </Border>

            <!-- Configuration Card -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel Spacing="10">
                    <TextBlock Text="CONFIGURATION" Style="{StaticResource SectionTitle}" />
                    <Border Style="{StaticResource PreviewPanel}" HorizontalAlignment="Stretch">
                        <TextBlock Text="{x:Bind ViewModel.IdlePreview, Mode=OneWay}"
                                   Foreground="{StaticResource AccentGlowBrush}" TextWrapping="Wrap" />
                    </Border>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Desk break: Sleep after 10m"
                                Command="{x:Bind ViewModel.UseDeskBreakTemplateCommand}"
                                Style="{StaticResource SubtleButton}" />
                        <Button Content="Bedtime: Shutdown after 15m"
                                Command="{x:Bind ViewModel.UseBedtimeTemplateCommand}"
                                Style="{StaticResource SubtleButton}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <NumberBox Header="Idle threshold (minutes)"
                                   Value="{x:Bind ViewModel.IdleMinutes, Mode=TwoWay}"
                                   Minimum="1" Maximum="999"
                                   SpinButtonPlacementMode="Compact" Width="200" />
                        <ComboBox Header="Action" Width="180"
                                  ItemsSource="{x:Bind ViewModel.AvailableActions}"
                                  SelectedItem="{x:Bind ViewModel.SelectedAction, Mode=TwoWay}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Controls -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Start Monitoring"
                                Command="{x:Bind ViewModel.StartMonitoringCommand}"
                                IsEnabled="{x:Bind ViewModel.IsMonitoring, Mode=OneWay, Converter={StaticResource InverseBool}}"
                                Style="{StaticResource GlowAccentButton}" />
                        <Button Content="Stop"
                                Command="{x:Bind ViewModel.StopMonitoringCommand}"
                                IsEnabled="{x:Bind ViewModel.IsMonitoring, Mode=OneWay}"
                                Style="{StaticResource DangerButton}" />
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
