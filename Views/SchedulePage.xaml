<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ShutdownTimer.Views.SchedulePage"
    x:Name="ScheduleRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:ShutdownTimer.Models"
    xmlns:vm="using:ShutdownTimer.ViewModels"
    Background="Transparent">

    <ScrollViewer Padding="22,16,22,14">
        <StackPanel Spacing="10" MaxWidth="900" HorizontalAlignment="Left">

            <!-- Page Title -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="SCHEDULE BUILDER" Style="{StaticResource PageEyebrow}" />
                    <TextBlock Text="Plan repeatable power actions" Style="{StaticResource PageHeading}" />
                    <TextBlock Text="Create one-time or recurring automations with a clear preview before they are saved."
                               Style="{StaticResource PageDescription}" />
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource HelpInfoButton}" VerticalAlignment="Top">
                    <FontIcon Glyph="&#xE897;" FontSize="16" />
                    <Button.Flyout>
                        <Flyout Placement="BottomEdgeAlignedRight">
                            <StackPanel Spacing="8" MaxWidth="300">
                                <TextBlock Text="Schedule Help" FontWeight="SemiBold" Foreground="{ThemeResource PageTitleForeground}" />
                                <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource SubtleForeground}" FontSize="13"
                                           Text="Create recurring schedules for specific days, or use One-time mode for a specific date and time." />
                                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource AccentWarmBrush}" FontSize="12"
                                           Text="Tip: The app must be running (even minimized to tray) for schedules to trigger." />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!-- 7-Day Calendar Preview -->
            <Border Style="{StaticResource GlowCard}" Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="UPCOMING (7 DAYS)" Style="{StaticResource SectionTitle}" />
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.CalendarWeek, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="6" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:CalendarDayGroup">
                                <Border CornerRadius="8" Padding="7,5" MinWidth="76"
                                        Background="{ThemeResource GlassCardBrush}"
                                        BorderBrush="{ThemeResource CardBorderBrush}"
                                        BorderThickness="1">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{x:Bind DayLabel}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{ThemeResource PageTitleForeground}"
                                                   HorizontalAlignment="Center" />
                                        <ItemsRepeater ItemsSource="{x:Bind Events}">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Spacing="2" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:CalendarEvent">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="{x:Bind Time}" FontSize="10"
                                                                   Foreground="{StaticResource AccentGlowBrush}" FontFamily="Consolas" />
                                                        <TextBlock FontSize="10" Foreground="{ThemeResource SubtleForeground}">
                                                            <Run Text="{x:Bind Action}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                        <!-- Empty day placeholder -->
                                        <TextBlock Text="—" FontSize="10" Foreground="{ThemeResource DimForeground}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </Border>

            <!-- Add new schedule card -->
            <Border Style="{StaticResource GlassCard}">
                <StackPanel Spacing="8">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="ADD SCHEDULE" Style="{StaticResource SectionTitle}" Margin="0" VerticalAlignment="Center" />
                        <ToggleSwitch IsOn="{x:Bind ViewModel.IsOneTimeMode, Mode=TwoWay}"
                                      OnContent="One-time" OffContent="Recurring"
                                      MinWidth="0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Border Style="{StaticResource PreviewPanel}" HorizontalAlignment="Stretch">
                        <TextBlock Text="{x:Bind ViewModel.SchedulePreview, Mode=OneWay}"
                                   Foreground="{StaticResource AccentGlowBrush}" TextWrapping="Wrap" />
                    </Border>

                    <!-- Recurring mode inputs -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsOneTimeMode, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}"
                                Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <NumberBox Header="Hour (0-23)" Value="{x:Bind ViewModel.NewHour, Mode=TwoWay}"
                                       Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" Width="120" />
                            <NumberBox Header="Minute (0-59)" Value="{x:Bind ViewModel.NewMinute, Mode=TwoWay}"
                                       Minimum="0" Maximum="59" SpinButtonPlacementMode="Compact" Width="120" />
                            <ComboBox Header="Action" Width="150"
                                      ItemsSource="{x:Bind ViewModel.AvailableActions}"
                                      SelectedItem="{x:Bind ViewModel.NewAction, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- Day selection -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox Content="Mon" IsChecked="{x:Bind ViewModel.MonSelected, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Tue" IsChecked="{x:Bind ViewModel.TueSelected, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Wed" IsChecked="{x:Bind ViewModel.WedSelected, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Thu" IsChecked="{x:Bind ViewModel.ThuSelected, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Fri" IsChecked="{x:Bind ViewModel.FriSelected, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Sat" IsChecked="{x:Bind ViewModel.SatSelected, Mode=TwoWay}" MinWidth="0" />
                            <CheckBox Content="Sun" IsChecked="{x:Bind ViewModel.SunSelected, Mode=TwoWay}" MinWidth="0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="All" Command="{x:Bind ViewModel.SelectAllDaysCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,4" FontSize="11" />
                            <Button Content="Weekdays" Command="{x:Bind ViewModel.SelectWeekdaysCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,4" FontSize="11" />
                            <Button Content="Weekends" Command="{x:Bind ViewModel.SelectWeekendsCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,4" FontSize="11" />
                        </StackPanel>
                    </StackPanel>

                    <!-- One-time mode inputs -->
                    <StackPanel Visibility="{x:Bind ViewModel.IsOneTimeMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"
                                Spacing="8">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <CalendarDatePicker Header="Date" Date="{x:Bind ViewModel.OneTimeDate, Mode=TwoWay}" Width="200" />
                            <NumberBox Header="Hour (0-23)" Value="{x:Bind ViewModel.OneTimeHour, Mode=TwoWay}"
                                       Minimum="0" Maximum="23" SpinButtonPlacementMode="Compact" Width="120" />
                            <NumberBox Header="Minute (0-59)" Value="{x:Bind ViewModel.OneTimeMinute, Mode=TwoWay}"
                                       Minimum="0" Maximum="59" SpinButtonPlacementMode="Compact" Width="120" />
                        </StackPanel>
                        <ComboBox Header="Action" Width="150"
                                  ItemsSource="{x:Bind ViewModel.AvailableActions}"
                                  SelectedItem="{x:Bind ViewModel.NewAction, Mode=TwoWay}" />
                    </StackPanel>

                    <Button Content="Add Schedule" Command="{x:Bind ViewModel.AddScheduleCommand}"
                            Style="{StaticResource GlowAccentButton}" />

                    <!-- Quick Templates -->
                    <StackPanel Spacing="6" Margin="0,2,0,0">
                        <TextBlock Text="QUICK TEMPLATES" Style="{StaticResource SectionTitle}" FontSize="10" Opacity="0.8" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button Content="11pm Weeknights" Command="{x:Bind ViewModel.Add11pmWeeknightsCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,6" FontSize="11" />
                            <Button Content="9pm Bedtime" Command="{x:Bind ViewModel.AddBedtimeWeekdaysCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,6" FontSize="11" />
                            <Button Content="Midnight Daily" Command="{x:Bind ViewModel.AddMidnightDailyCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,6" FontSize="11" />
                            <Button Content="1am Weekends" Command="{x:Bind ViewModel.AddWeekendMornings1amCommand}"
                                    Style="{StaticResource SubtleButton}" Padding="10,6" FontSize="11" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Schedule list -->
            <Border Style="{StaticResource GlassCard}" Padding="0">
                <ListView ItemsSource="{x:Bind ViewModel.Schedules, Mode=OneWay}"
                          SelectionMode="None" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ScheduleEntry">
                            <Grid Padding="16,10" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ToggleSwitch Grid.Column="0" IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                              OnContent="" OffContent="" MinWidth="0" />

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{x:Bind FriendlyDescription}" FontWeight="SemiBold"
                                               Foreground="{ThemeResource PageTitleForeground}" />
                                    <TextBlock FontSize="12" Foreground="{ThemeResource SubtleForeground}">
                                        <Run Text="Action: " /><Run Text="{x:Bind Action}" />
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{x:Bind NextRunDisplay}" FontSize="11"
                                                   Foreground="{StaticResource AccentGlowDimBrush}" />
                                        <TextBlock Text="{x:Bind LastRunDisplay}" FontSize="11"
                                                   Foreground="{ThemeResource DimForeground}" />
                                        <TextBlock Text="{x:Bind HealthText}" FontSize="11"
                                                   Foreground="{ThemeResource DimForeground}" />
                                    </StackPanel>
                                    <TextBlock FontSize="11" Foreground="{StaticResource AccentRedBrush}"
                                               Text="{x:Bind CronError}"
                                               Visibility="{x:Bind CronError, Converter={StaticResource StringToVisibility}}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Grid.Column="2" FontSize="11"
                                           Foreground="{ThemeResource DimForeground}"
                                           VerticalAlignment="Center" FontFamily="Consolas"
                                           Text="{x:Bind CronExpression}" />

                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                    <Button Content="Duplicate"
                                            Command="{Binding ElementName=ScheduleRoot, Path=ViewModel.DuplicateScheduleCommand}"
                                            CommandParameter="{x:Bind}"
                                            Style="{StaticResource SubtleButton}"
                                            Padding="10,6" />
                                    <Button Content="Remove"
                                            Command="{Binding ElementName=ScheduleRoot, Path=ViewModel.RemoveScheduleCommand}"
                                            CommandParameter="{x:Bind}"
                                            Style="{StaticResource DangerButton}"
                                            Padding="10,6" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Status -->
            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       FontSize="13" Foreground="{ThemeResource SubtleForeground}" />
        </StackPanel>
    </ScrollViewer>
</Page>
